# Set this in production (e.g. on Vercel) to the full origin of your deployed
# backend — no trailing slash, no /api suffix. The client appends /api itself.
#
# Examples:
#   VITE_API_BASE_URL=https://yourname-codesage.hf.space
#   VITE_API_BASE_URL=https://api.example.com
#
# Leave it unset locally — the Vite dev server proxies /api to localhost:8000.
VITE_API_BASE_URL=
