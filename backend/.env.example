PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=codesage
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional. CodeSage only supports PUBLIC repositories.
# Without a token, GitHub limits anonymous API calls to 60/hour per IP — the
# Structure tab (branch list + file tree) will rate-limit on heavy use.
# Add a fine-grained token (no scopes needed for public repos) to raise the
# limit to 5,000/hour. Generate one at:
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Optional overrides
# Default (fast, generic, 384 dim):
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Recommended for code-heavy repos (768 dim, code-aware) — requires a fresh Pinecone index:
# EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LOG_LEVEL=INFO
# Comma-separated CORS origins for the API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to 0 to skip pre-loading the embedding model at startup
WARMUP_EMBEDDER=1
